# =============================================================================
# TODO: Copy this file to .env and fill in your credentials (POC; no DB).
# =============================================================================

# Google OAuth (your app) — get from Google Cloud Console
GOOGLE_CLIENT_SECRETS_FILE=client_secret.json
GOOGLE_REDIRECT_URI=http://localhost:8000/oauth/callback-ui

# Pinecone — create index and copy API key + index name
PINECONE_API_KEY=
PINECONE_INDEX=knowledge-base

# OpenAI — for RAG embedding and chat
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# Airbyte — optional; base URL only (no path suffix; app uses AIRBYTE_API_PATH_*)
# Cloud: https://api.airbyte.com  |  OSS local: http://localhost:8000
AIRBYTE_API_URL=https://api.airbyte.com
AIRBYTE_WORKSPACE_ID=

# OSS only: API path prefixes (Cloud uses /v1; OSS uses /api/v1 and /api/public/v1)
# AIRBYTE_API_PATH_AUTH=/api/v1
# AIRBYTE_API_PATH_PUBLIC=/api/public/v1

# Set to 1 to use Airbyte API only (no PyAirbyte). Required for OSS/Cloud production.
# AIRBYTE_USE_API=1

# Optional: increase if Airbyte API is slow (default 90 seconds)
# AIRBYTE_REQUEST_TIMEOUT=90

# Airbyte Cloud/OSS: Application credentials (Cloud: Settings → Account → Applications; OSS: User Settings → Applications)
AIRBYTE_CLIENT_ID=
AIRBYTE_CLIENT_SECRET=

# Or static token (self-hosted): set AIRBYTE_API_KEY and leave CLIENT_ID/SECRET empty
# AIRBYTE_API_KEY=

# Optional: from Airbyte connector registry (get from Airbyte UI or API)
# AIRBYTE_SOURCE_DEFINITION_ID_GOOGLE_DRIVE=
# AIRBYTE_DESTINATION_DEFINITION_ID_PINECONE=

# When using OSS on 8000, run POC on 8001 and set:
# GOOGLE_REDIRECT_URI=http://localhost:8001/oauth/callback-ui
# OPENAI_EMBED_DIMENSIONS=1024  (match Pinecone index dimension)
